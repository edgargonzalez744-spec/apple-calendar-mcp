# Copy to .env and fill in. Required.
# Your Apple ID email:
ICLOUD_USERNAME=you@icloud.com
# An APP-SPECIFIC password (NOT your normal Apple password).
# Generate at https://account.apple.com -> Sign-In and Security -> App-Specific Passwords
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: timezone used when an event time has no offset (default UTC).
# e.g. America/New_York, Europe/Madrid
CALDAV_DEFAULT_TZ=UTC

# Optional: override the CalDAV endpoint (default is iCloud).
# CALDAV_URL=https://caldav.icloud.com/

# Optional: subscription calendars (holidays, sports, birthdays, shared feeds).
# iCloud does NOT expose these over CalDAV, so add their feed URLs here to read
# them directly. Whitespace- or comma-separated. webcal:// is fine.
# EXTRA_ICS_FEEDS=https://example.com/holidays.ics  webcal://example.com/team.ics
